# SDKWork private bootstrap credential (blank in tracked files).
# Resolved tokens belong in .env.<mode>.bootstrap.local only.

SDKWORK_ACCESS_TOKEN=

# Optional local dev API proxy overrides (Vite dev server only).
# Defaults to the platform gateway at http://127.0.0.1:3900 when unset.
# SDKWORK_MALL_PC_DEV_APP_API_PROXY_TARGET=http://127.0.0.1:3900
# SDKWORK_MALL_PC_DEV_BACKEND_API_PROXY_TARGET=http://127.0.0.1:3900
# VITE_SDKWORK_COMMERCE_PC_APP_API_BASE_URL=http://127.0.0.1:18082/app/v3/api
