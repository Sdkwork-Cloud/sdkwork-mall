{
  "environment": "development",
  "configProfile": "dev",
  "buildMode": "development",
  "deploymentMode": "web",
  "runtimeTarget": "browser",
  "appKey": "sdkwork-mall-pc",
  "appApiBaseUrl": "http://127.0.0.1:18082/app/v3/api",
  "backendApiBaseUrl": "http://127.0.0.1:18083/backend/v3/api",
  "sdkBaseUrls": {
    "sdkBaseUrl": "http://127.0.0.1:18080",
    "appApiBaseUrl": "http://127.0.0.1:18082/app/v3/api",
    "backendApiBaseUrl": "http://127.0.0.1:18083/backend/v3/api",
    "dependencySdkBaseUrls": {
      "sdkwork-iam-app-sdk": {
        "appApiBaseUrl": "http://127.0.0.1:18082/app/v3/api"
      },
      "sdkwork-iam-backend-sdk": {
        "backendApiBaseUrl": "http://127.0.0.1:18083/backend/v3/api"
      }
    }
  },
  "auth": {
    "tokenManagerMode": "appbase-global",
    "tokenStorage": "browser-session",
    "accessTokenHeader": "Access-Token",
    "authTokenHeader": "Authorization",
    "refreshEnabled": true
  },
  "i18n": {
    "defaultLocale": "zh-CN",
    "supportedLocales": ["zh-CN", "en-US"],
    "fallbackLocale": "en-US"
  },
  "publicRuntime": {
    "runtimeEnvFile": "/runtime-env.json",
    "appApiBaseUrl": "http://127.0.0.1:18082/app/v3/api",
    "backendApiBaseUrl": "http://127.0.0.1:18083/backend/v3/api"
  }
}
