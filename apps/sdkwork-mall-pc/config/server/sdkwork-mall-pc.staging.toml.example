[runtime]
environment = "staging"
config_profile = "staging"
build_mode = "staging"
deployment_mode = "server"
runtime_target = "server"
app_key = "sdkwork-mall-pc"

[sdk_base_urls]
sdk_base_url = "https://staging-api.sdkwork.com"
app_api_base_url = "https://staging-api.sdkwork.com/app/v3/api"
backend_api_base_url = "https://staging-api.sdkwork.com/backend/v3/api"

[server]
bind = "0.0.0.0:18082"
external_scheme = "https"
trust_forwarded_headers = true

[database]
engine = "postgresql"
host = "db.staging.internal"
port = 5432
database = "sdkwork"
schema = "public"
username = "sdkwork"
password_file = "/etc/sdkwork/commerce-pc/database.secret"
ssl_mode = "require"
max_connections = 20

[redis]
enabled = true
host = "redis.staging.internal"
port = 6379
database = 0
password_file = "/etc/sdkwork/commerce-pc/redis.secret"
key_prefix = "sdkwork-mall-pc:staging"
