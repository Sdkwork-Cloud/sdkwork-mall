[runtime]
environment = "test"
config_profile = "test"
build_mode = "test"
deployment_mode = "server"
runtime_target = "test-runner"
app_key = "sdkwork-mall-pc"

[sdk_base_urls]
sdk_base_url = "http://127.0.0.1:19080"
app_api_base_url = "http://127.0.0.1:19082/app/v3/api"
backend_api_base_url = "http://127.0.0.1:19083/backend/v3/api"

[server]
bind = "127.0.0.1:19082"
external_scheme = "http"
trust_forwarded_headers = false

[database]
engine = "postgresql"
host = "127.0.0.1"
port = 5432
database = "sdkwork_commerce_pc_test"
schema = "public"
username = "sdkworktest"
password_file = "config/server/test-database.secret.local"
ssl_mode = "disable"
max_connections = 5

[redis]
enabled = true
host = "127.0.0.1"
port = 6379
database = 1
password_file = "config/server/test-redis.secret.local"
key_prefix = "sdkwork-mall-pc:test"
