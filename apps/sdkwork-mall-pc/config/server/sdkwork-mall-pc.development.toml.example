[runtime]
environment = "development"
config_profile = "dev"
build_mode = "development"
deployment_mode = "server"
runtime_target = "server"
app_key = "sdkwork-mall-pc"

[sdk_base_urls]
sdk_base_url = "http://127.0.0.1:18080"
app_api_base_url = "http://127.0.0.1:18082/app/v3/api"
backend_api_base_url = "http://127.0.0.1:18083/backend/v3/api"

[server]
bind = "127.0.0.1:18082"
external_scheme = "http"
trust_forwarded_headers = false

[database]
engine = "postgresql"
host = "127.0.0.1"
port = 5432
database = "sdkwork_ai_dev"
schema = "sdkwork_ai_dev"
username = "sdkwork_ai_dev"
password_file = "config/server/development-database.secret.local"
ssl_mode = "disable"
max_connections = 10

[redis]
enabled = true
host = "127.0.0.1"
port = 6379
database = 0
password_file = "config/server/development-redis.secret.local"
key_prefix = "sdkwork-mall-pc:dev"
