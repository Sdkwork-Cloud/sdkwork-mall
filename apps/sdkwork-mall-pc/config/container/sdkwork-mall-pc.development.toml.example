[runtime]
environment = "development"
config_profile = "dev"
build_mode = "development"
deployment_mode = "container"
runtime_target = "container"
app_key = "sdkwork-mall-pc"

[sdk_base_urls]
sdk_base_url = "http://commerce-gateway:18080"
app_api_base_url = "http://commerce-app-api:18082/app/v3/api"
backend_api_base_url = "http://commerce-backend-api:18083/backend/v3/api"

[server]
bind = "0.0.0.0:18082"
external_scheme = "http"
trust_forwarded_headers = true

[database]
engine = "postgresql"
host = "postgres"
port = 5432
database = "sdkwork_ai_dev"
schema = "sdkwork_ai_dev"
username = "sdkwork_ai_dev"
password_file = "/run/secrets/commerce-pc/database-password"
ssl_mode = "disable"
max_connections = 10

[redis]
enabled = true
host = "redis"
port = 6379
database = 0
password_file = "/run/secrets/commerce-pc/redis-password"
key_prefix = "sdkwork-mall-pc:dev"
