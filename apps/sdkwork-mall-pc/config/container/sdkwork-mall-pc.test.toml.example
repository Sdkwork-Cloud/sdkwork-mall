[runtime]
environment = "test"
config_profile = "test"
build_mode = "test"
deployment_mode = "container"
runtime_target = "test-runner"
app_key = "sdkwork-mall-pc"

[sdk_base_urls]
sdk_base_url = "http://commerce-gateway-test:19080"
app_api_base_url = "http://commerce-app-api-test:19082/app/v3/api"
backend_api_base_url = "http://commerce-backend-api-test:19083/backend/v3/api"

[server]
bind = "0.0.0.0:19082"
external_scheme = "http"
trust_forwarded_headers = true

[database]
engine = "postgresql"
host = "postgres-test"
port = 5432
database = "sdkwork_commerce_pc_test"
schema = "sdkwork_ai_prod"
username = "sdkworktest"
password_file = "/run/secrets/commerce-pc/test-database-password"
ssl_mode = "disable"
max_connections = 5

[redis]
enabled = true
host = "redis-test"
port = 6379
database = 1
password_file = "/run/secrets/commerce-pc/test-redis-password"
key_prefix = "sdkwork-mall-pc:test"
