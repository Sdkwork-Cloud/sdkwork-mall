[runtime]
environment = "development"
config_profile = "dev"
build_mode = "development"
deployment_mode = "desktop"
runtime_target = "desktop"
app_key = "sdkwork-mall-pc"

[sdk_base_urls]
sdk_base_url = "http://127.0.0.1:18080"
app_api_base_url = "http://127.0.0.1:18082/app/v3/api"
backend_api_base_url = "http://127.0.0.1:18083/backend/v3/api"

[auth]
token_manager_mode = "appbase-global"
token_storage = "os-secure-storage"
access_token_header = "Access-Token"
auth_token_header = "Authorization"
refresh_enabled = true

[desktop]
native_host = "tauri"
local_service_enabled = true
local_service_bind = "127.0.0.1:18082"
user_config_file = "~/.sdkwork/commerce-pc/config/sdkwork-mall-pc.toml"
secure_storage_provider = "os"

[database]
engine = "sqlite"
file = "~/.sdkwork/commerce-pc/data/sdkwork-mall-pc-dev.sqlite"
max_connections = 1

[redis]
enabled = false
