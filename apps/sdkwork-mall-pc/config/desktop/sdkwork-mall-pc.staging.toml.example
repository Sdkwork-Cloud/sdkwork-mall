[runtime]
environment = "staging"
config_profile = "staging"
build_mode = "staging"
deployment_mode = "desktop"
runtime_target = "desktop"
app_key = "sdkwork-mall-pc"

[sdk_base_urls]
sdk_base_url = "https://staging-api.sdkwork.com"
app_api_base_url = "https://staging-api.sdkwork.com/app/v3/api"
backend_api_base_url = "https://staging-api.sdkwork.com/backend/v3/api"

[auth]
token_manager_mode = "appbase-global"
token_storage = "os-secure-storage"
access_token_header = "Access-Token"
auth_token_header = "Authorization"
refresh_enabled = true

[desktop]
native_host = "tauri"
local_service_enabled = false
user_config_file = "~/.sdkwork/commerce-pc/config/sdkwork-mall-pc.staging.toml"
secure_storage_provider = "os"

[database]
engine = "sqlite"
file = "~/.sdkwork/commerce-pc/data/sdkwork-mall-pc-staging.sqlite"
max_connections = 1

[redis]
enabled = false
