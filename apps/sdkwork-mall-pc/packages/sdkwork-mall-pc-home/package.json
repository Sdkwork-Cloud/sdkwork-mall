{
  "name": "@sdkwork/mall-pc-home",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mall storefront home page and help center.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./routes": {
      "types": "./src/routes.ts",
      "import": "./src/routes.ts",
      "default": "./src/routes.ts"
    },
    "./storefront-pages": {
      "types": "./src/storefront-pages.ts",
      "import": "./src/storefront-pages.ts",
      "default": "./src/storefront-pages.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sdkwork/payment-service": "*",
    "@sdkwork/mall-pc-cms": "*",
    "@sdkwork/mall-pc-core": "*",
    "@sdkwork/mall-pc-reviews": "*",
    "@sdkwork/mall-pc-search": "*",
    "@sdkwork/ui-pc-react": "*",
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0",
    "react-router-dom": ">=6.0.0 <8.0.0"
  },
  "sdkwork": {
    "workspace": "sdkwork-mall",
    "architecture": "pc-react",
    "domain": "commerce",
    "capability": "home",
    "status": "ready"
  }
}
