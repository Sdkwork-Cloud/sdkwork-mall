{
  "name": "@sdkwork/mall-pc-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SDKWork Mall PC application composition root.",
  "scripts": {
    "dev": "node ../../../sdkwork-iam/scripts/dev/run-pc-renderer-dev-with-bootstrap.mjs -- vite --host 127.0.0.1 --port 5175",
    "dev:server": "node -e \"console.log('Mall PC server development profile: apps/sdkwork-mall-pc/config/server/sdkwork-mall-pc.development.toml.example')\"",
    "build": "vite build",
    "build:staging": "node scripts/validate-runtime-config.mjs --profile staging && vite build --mode staging",
    "build:prod": "node scripts/validate-runtime-config.mjs --profile production && vite build --mode production",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm --dir ../.. run test:vitest",
    "test:config": "node --test ../../tests/contract/verify-mall-standard-architecture.test.mjs && node scripts/validate-runtime-config.mjs --all",
    "lint": "pnpm run typecheck"
  },
