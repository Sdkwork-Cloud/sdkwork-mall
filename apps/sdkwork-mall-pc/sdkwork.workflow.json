{
  "$schema": "https://sdkwork.com/schemas/sdkwork-workflow.schema.json",
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-mall-pc",
    "name": "SDKWork Mall PC",
    "repository": "Sdkwork-Cloud/sdkwork-mall",
    "sourcePath": "apps/sdkwork-mall-pc",
    "configPath": "sdkwork.app.config.json"
  },
  "release": {
    "artifactPrefix": "sdkwork-mall-pc",
    "defaultVersion": "0.1.0",
    "versionInput": "package_version",
    "tagInput": "tag",
    "changelog": {
      "source": "app-manifest"
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "refInput": "SDKWORK_APPBASE_REF",
      "path": "sdkwork-appbase",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-ui",
      "repository": "Sdkwork-Cloud/sdkwork-ui",
      "refInput": "SDKWORK_UI_REF",
      "path": "sdkwork-ui",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-commons",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-commons",
      "refInput": "SDKWORK_SDK_COMMONS_REF",
      "path": "sdkwork-sdk-commons",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-utils",
      "repository": "Sdkwork-Cloud/sdkwork-utils",
      "refInput": "SDKWORK_UTILS_REF",
      "path": "sdkwork-utils",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-core",
      "repository": "Sdkwork-Cloud/sdkwork-core",
      "refInput": "SDKWORK_CORE_REF",
      "path": "sdkwork-core",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.33.0"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install Mall workspace dependencies",
        "shell": "pwsh",
        "workingDirectory": ".",
        "run": "pnpm install --frozen-lockfile"
      }
    ],
    "build": [
      {
        "name": "Verify Mall PC workspace and build production bundle",
        "shell": "pwsh",
        "workingDirectory": ".",
        "run": "pnpm run verify\npnpm run build"
      }
    ],
    "stage": [
      {
        "name": "Stage Mall PC web bundle metadata",
        "shell": "pwsh",
        "workingDirectory": ".",
        "run": "$ErrorActionPreference = \"Stop\"\n$stage = \"apps/sdkwork-mall-pc/dist/web\"\nRemove-Item -LiteralPath $stage -Recurse -Force -ErrorAction SilentlyContinue\nNew-Item -ItemType Directory -Force -Path $stage | Out-Null\nCopy-Item -LiteralPath \"apps/sdkwork-mall-pc/sdkwork.app.config.json\" -Destination \"$stage/sdkwork.app.config.json\"\nCopy-Item -LiteralPath \"apps/sdkwork-mall-pc/README.md\" -Destination \"$stage/README.md\""
      }
    ],
    "package": [
      {
        "name": "Package selected Mall PC web target",
        "shell": "pwsh",
        "workingDirectory": ".",
        "run": "$ErrorActionPreference = \"Stop\"\n$output = \"apps/sdkwork-mall-pc/dist/sdkwork-mall-pc-$env:SDKWORK_PACKAGE_ID-$env:SDKWORK_PACKAGE_VERSION.zip\"\nCompress-Archive -Path \"apps/sdkwork-mall-pc/dist/web/*\" -DestinationPath $output -Force"
      }
    ],
    "validate": [
      {
        "name": "Validate selected Mall PC package",
        "shell": "pwsh",
        "workingDirectory": ".",
        "run": "$ErrorActionPreference = \"Stop\"\n$artifact = Get-ChildItem -Path \"apps/sdkwork-mall-pc/dist\" -File | Where-Object { $_.Name -like \"sdkwork-mall-pc-$env:SDKWORK_PACKAGE_ID-$env:SDKWORK_PACKAGE_VERSION.zip\" } | Select-Object -First 1\nif (-not $artifact) { throw \"Missing Mall PC artifact for $env:SDKWORK_PACKAGE_ID\" }\npnpm run test:node"
      }
    ]
  },
  "targets": [
    {
      "id": "web-universal-cloud-browser-zip",
      "profile": "browser",
      "platform": "web",
      "architecture": "universal",
      "formats": [
        "zip"
      ],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "apps/sdkwork-mall-pc/dist/*.zip"
      ],
      "deploymentProfile": "cloud",
      "runtimeTarget": "browser"
    }
  ],
  "security": {
    "signingRequired": false,
    "sbomRequired": false,
    "artifactAttestations": true
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": true,
    "retentionDays": 30
  }
}
